{
  "description": "TLF35584 PMIC Driver - Default Parameters",
  "note": "ALL register addresses verified against Infineon TLF35584 datasheet v02_00-EN",
  "_locked_params_warning": "Parameters with locked=true MUST NOT be modified by LLM or user",

  "version": "2.0.0",
  "prefix": "Gp_TLF35584",
  "module_prefix": "TLF35584",

  "spi": {
    "max_freq_hz": 10000000,
    "recommended_freq_hz": 5000000,
    "cpol": 0,
    "cpha": 1,
    "timeout_us": 1000,
    "retry_max": 3,
    "locked": true,
    "comment": "CPOL=0, CPHA=1 is the only supported SPI mode for TLF35584"
  },

  "init": {
    "retry_max": 4,
    "retry_delay_us": 100,
    "state_change_delay_us": 5000,
    "locked": true,
    "comment": "Init retry max 4 per datasheet recommendation"
  },

  "watchdog": {
    "fwd_fail_max": 5,
    "fwd_service_interval_ms": 10,
    "wwd_service_interval_ms": 10,
    "locked": false,
    "comment": "Watchdog timing is application-dependent, user may override"
  },

  "bist": {
    "enable_on_init": 1,
    "timeout_us": 100000,
    "locked": false
  },

  "emb_recovery": {
    "fast_delay_us": 100,
    "slow_delay_us": 1000,
    "locked": false
  },

  "fault_monitoring": {
    "poll_interval_ms": 10,
    "sample_max": 3,
    "clear_value": 255,
    "clear_value_hex": "0xFF",
    "readback_verify": true,
    "locked": true,
    "comment": "0xFF clear (rw1c) + readback verify for stuck-at immunity"
  },

