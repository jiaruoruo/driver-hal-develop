/**
 * @file           ZCU_TLF35584_MemMap.h
 * @brief          TLF35584 PMIC Driver - Memory Section Mapping
 * @version        {{ VERSION }}
 * @asil           ASIL-D
 * =============================================================================
 * [TEMPLATE LOCKED v2.0]
 * Memory section definitions for TASKING, HIGHTEC and GCC compilers.
 *
 * Sections:
 * - {{ MODULE_PREFIX }}_START_SEC_ASILD_PRIVATE_BSW_DATA     â†?ASIL-D private data
 * - {{ MODULE_PREFIX }}_START_SEC_MULTI_APP_SHARE_BSW_DATA   â†?Multi-app share data
 * - {{ MODULE_PREFIX }}_START_SEC_CONST_ASIL                 â†?ASIL-D constants (FWD table)
 * - {{ MODULE_PREFIX }}_START_SEC_CODE                       â†?Code section
 * =============================================================================
 */
#ifndef ZCU_TLF35584_MEMMAP_H
#define ZCU_TLF35584_MEMMAP_H

/*===========================================================================*/
/* Compiler Detection                                                        */
/*===========================================================================*/
#if defined(__TASKING__)
    /* TASKING Compiler (TriCore) */
    #define {{ MODULE_PREFIX }}_START_SEC_ASILD_PRIVATE_BSW_DATA \
        __attribute__((section ".bss.asild_private_bsw_data"))
    #define {{ MODULE_PREFIX }}_STOP_SEC_ASILD_PRIVATE_BSW_DATA

    #define {{ MODULE_PREFIX }}_START_SEC_MULTI_APP_SHARE_BSW_DATA \
        __attribute__((section ".bss.multi_app_share_bsw_data"))
    #define {{ MODULE_PREFIX }}_STOP_SEC_MULTI_APP_SHARE_BSW_DATA

    #define {{ MODULE_PREFIX }}_START_SEC_CONST_ASIL \
        __attribute__((section ".rodata.const_asil"))
    #define {{ MODULE_PREFIX }}_STOP_SEC_CONST_ASIL

    #define {{ MODULE_PREFIX }}_START_SEC_CODE \
        __attribute__((section ".text.pmic_driver"))
    #define {{ MODULE_PREFIX }}_STOP_SEC_CODE

#elif defined(__HIGHTEC__)
    /* HIGHTEC Compiler (TriCore/GCC-based) */
    #define {{ MODULE_PREFIX }}_START_SEC_ASILD_PRIVATE_BSW_DATA \
        __attribute__((section ".bss.asild_private_bsw_data"))
    #define {{ MODULE_PREFIX }}_STOP_SEC_ASILD_PRIVATE_BSW_DATA

    #define {{ MODULE_PREFIX }}_START_SEC_MULTI_APP_SHARE_BSW_DATA \
        __attribute__((section ".bss.multi_app_share_bsw_data"))
    #define {{ MODULE_PREFIX }}_STOP_SEC_MULTI_APP_SHARE_BSW_DATA

    #define {{ MODULE_PREFIX }}_START_SEC_CONST_ASIL \
        __attribute__((section ".rodata.const_asil"))
    #define {{ MODULE_PREFIX }}_STOP_SEC_CONST_ASIL

    #define {{ MODULE_PREFIX }}_START_SEC_CODE \
        __attribute__((section ".text.pmic_driver"))
    #define {{ MODULE_PREFIX }}_STOP_SEC_CODE

#elif defined(__GNUC__)
    /* GCC Compiler (generic) */
    #define {{ MODULE_PREFIX }}_START_SEC_ASILD_PRIVATE_BSW_DATA \
        __attribute__((section ".bss.asild_private_bsw_data"))
    #define {{ MODULE_PREFIX }}_STOP_SEC_ASILD_PRIVATE_BSW_DATA

    #define {{ MODULE_PREFIX }}_START_SEC_MULTI_APP_SHARE_BSW_DATA \
        __attribute__((section ".bss.multi_app_share_bsw_data"))
    #define {{ MODULE_PREFIX }}_STOP_SEC_MULTI_APP_SHARE_BSW_DATA

    #define {{ MODULE_PREFIX }}_START_SEC_CONST_ASIL \
        __attribute__((section ".rodata.const_asil"))
    #define {{ MODULE_PREFIX }}_STOP_SEC_CONST_ASIL

    #define {{ MODULE_PREFIX }}_START_SEC_CODE \
        __attribute__((section ".text.pmic_driver"))
    #define {{ MODULE_PREFIX }}_STOP_SEC_CODE

#else
    #error "Unsupported compiler. Only TASKING, HIGHTEC, and GCC are supported."
#endif

#endif /* ZCU_TLF35584_MEMMAP_H */
