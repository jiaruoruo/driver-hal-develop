/*===========================================================================*/
/* SPI Protocol â€?Frame Construction with Even Parity                        */
/* Algorithm: LOCKED â€?DO NOT MODIFY                                        */
/*===========================================================================*/
static uint8 {{ PREFIX }}_CalcParity(uint16 frame16)
{
    uint8 parity = 0U;
    uint16 tmp = frame16;
    while (tmp != 0U)
    {
        parity ^= (uint8)(tmp & 1U);
        tmp >>= 1U;
    }
    return parity;
}

static uint16 {{ PREFIX }}_BuildFrame(uint8 addr, uint8 data, uint8 cmd)
{
    uint16 frame;
    frame = (uint16)(((uint16)data << {{ PREFIX }}_SPI_DATA_BIT_POS) |
                     ((uint16)addr << {{ PREFIX }}_SPI_ADDR_BIT_POS) |
                     ((uint16)cmd  << {{ PREFIX }}_SPI_CMD_BIT));
    if ({{ PREFIX }}_CalcParity(frame) != 0U)
    {
        frame |= (uint16)(1U << {{ PREFIX }}_SPI_PARITY_BIT_POS);
    }
    return frame;
}

static uint8 {{ PREFIX }}_ExtractData(uint16 rxFrame)
{
    return (uint8)((rxFrame >> {{ PREFIX }}_SPI_DATA_BIT_POS) & {{ PREFIX }}_SPI_DATA_MASK);
}

/*===========================================================================*/
/* SPI Transfer â€?Protected by SuspendAllInterrupts                          */
/* LOCKED: All SPI access must use this path                                 */
/*===========================================================================*/
static Std_ReturnType {{ PREFIX }}_SpiXfer(uint16 txFrame, uint16 *rxFrame)
{
    Std_ReturnType status = E_NOT_OK;
    uint8 retry;

    if ((NULL_PTR == {{ PREFIX }}_CfgPtr) || (NULL_PTR == rxFrame))
    {
        return E_NOT_OK;
    }

    for (retry = 0U; retry < {{ PREFIX }}_CfgPtr->spiRetryMax; retry++)
    {
        /* ASIL-D: SPI transfer must be interrupt-protected */
        SuspendAllInterrupts();
        status = {{ PREFIX }}_CfgPtr->spiTxRxFunc(txFrame, rxFrame);
        ResumeAllInterrupts();

        if (E_OK == status) { break; }
    }

    return status;
}

static Std_ReturnType {{ PREFIX }}_SpiReadReg(uint8 addr, uint8 *data)
{
    uint16 txFrame = {{ PREFIX }}_BuildFrame(addr, 0U, {{ PREFIX }}_SPI_CMD_READ);
    uint16 rxFrame;
    Std_ReturnType status = {{ PREFIX }}_SpiXfer(txFrame, &rxFrame);
    if (E_OK == status)
    {
        *data = {{ PREFIX }}_ExtractData(rxFrame);
    }
    return status;
}

static Std_ReturnType {{ PREFIX }}_SpiWriteReg(uint8 addr, uint8 data)
{
    uint16 txFrame = {{ PREFIX }}_BuildFrame(addr, data, {{ PREFIX }}_SPI_CMD_WRITE);
    uint16 rxFrame;
    return {{ PREFIX }}_SpiXfer(txFrame, &rxFrame);
}

/*===========================================================================*/
/* Protection Register Unlock/Lock â€?LOCKED                                  */
/* Sequence values verified against datasheet                                */
/*===========================================================================*/
static const uint8 {{ PREFIX }}_UnlockBytes[{{ PREFIX }}_PROT_SEQ_LEN] =
{
    {{ PREFIX }}_UNLOCK_BYTE0, {{ PREFIX }}_UNLOCK_BYTE1,
    {{ PREFIX }}_UNLOCK_BYTE2, {{ PREFIX }}_UNLOCK_BYTE3
};

static const uint8 {{ PREFIX }}_LockBytes[{{ PREFIX }}_PROT_SEQ_LEN] =
{
    {{ PREFIX }}_LOCK_BYTE0, {{ PREFIX }}_LOCK_BYTE1,
    {{ PREFIX }}_LOCK_BYTE2, {{ PREFIX }}_LOCK_BYTE3
};

Std_ReturnType {{ PREFIX }}_UnlockProtRegs(void)
{
    Std_ReturnType status = E_OK;
    uint8 idx;
    for (idx = 0U; idx < {{ PREFIX }}_PROT_SEQ_LEN; idx++)
    {
        status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_PROTCFG,
                                          {{ PREFIX }}_UnlockBytes[idx]);
        if (E_OK != status) { return status; }
    }
    /* Readback verification: check PROTSTAT.LOCK bit */
    {
        uint8 protStat;
        (void){{ PREFIX }}_SpiReadReg({{ PREFIX }}_REG_PROTSTAT, &protStat);
        if ((protStat & 0x01U) != 0U)
        {
            status = E_NOT_OK;
        }
    }
    return status;
}

Std_ReturnType {{ PREFIX }}_LockProtRegs(void)
{
    Std_ReturnType status = E_OK;
    uint8 idx;
    for (idx = 0U; idx < {{ PREFIX }}_PROT_SEQ_LEN; idx++)
    {
        status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_PROTCFG,
                                          {{ PREFIX }}_LockBytes[idx]);
        if (E_OK != status) { return status; }
    }
    return status;
}

/*===========================================================================*/
/* Protected Register Write with Shadow Verification â€?ASIL-D requirement    */
/*===========================================================================*/
static Std_ReturnType {{ PREFIX }}_WriteShadowVerify(
    uint8 regAddr, uint8 value, uint8 shadowAddr)
{
    Std_ReturnType status = {{ PREFIX }}_UnlockProtRegs();
    if (E_OK != status) { return status; }

    status = {{ PREFIX }}_SpiWriteReg(regAddr, value);
    if (E_OK != status) { return status; }

    /* Shadow register readback verification (ASIL-D requirement) */
    {
        uint8 shadowVal;
        status = {{ PREFIX }}_SpiReadReg(shadowAddr, &shadowVal);
        if ((E_OK == status) && (shadowVal != value))
        {
            /* Shadow mismatch â€?stuck-at fault detection */
            {{ PREFIX }}_State.faultGroups[{{ PREFIX }}_FAULT_CHIP] |= {{ PREFIX }}_SYSTEM_ERR;
            status = E_NOT_OK;
        }
    }

    (void){{ PREFIX }}_LockProtRegs();
    return status;
}

/*===========================================================================*/
/* Device State Management â€?Complementary Write LOCKED                      */
/*===========================================================================*/
Std_ReturnType {{ PREFIX }}_SetState({{ PREFIX }}_DeviceStateType state)
{
    Std_ReturnType status;
    uint8 devctrlVal, devctrlnVal;

    if (state > {{ PREFIX }}_DEVSTATE_POWERDOWN) { return E_NOT_OK; }

    devctrlVal  = (uint8)state & {{ PREFIX }}_DEVCTRL_STATE_MSK;
    devctrlnVal = {{ PREFIX }}_DEVCTRLN_CMPL(devctrlVal);

    /* DEVCTRL and DEVCTRLN must be written as complementary pair (ASIL-D) */
    status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_DEVCTRL, devctrlVal);
    if (E_OK != status) { return status; }

    status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_DEVCTRLN, devctrlnVal);
    if (E_OK == status)
    {
        {{ PREFIX }}_State.targetState = state;
    }

    return status;
}

Std_ReturnType {{ PREFIX }}_GetState({{ PREFIX }}_DeviceStateType *state)
{
    uint8 devstat;
    Std_ReturnType status;

    if (NULL_PTR == state) { return E_NOT_OK; }

    status = {{ PREFIX }}_SpiReadReg({{ PREFIX }}_REG_DEVSTAT, &devstat);
    if (E_OK == status)
    {
        *state = ({{ PREFIX }}_DeviceStateType)(devstat & {{ PREFIX }}_DEVCTRL_STATE_MSK);
    }
    return status;
}

/*===========================================================================*/
/* FWD Watchdog Service â€?LOCKED                                             */
/*===========================================================================*/
Std_ReturnType {{ PREFIX }}_ServiceFwd(void)
{
    uint8 fwdstat0, fwdstat1, seed, errCnt;
    uint32 respVal;
    uint8 idx;
    Std_ReturnType status;

    status = {{ PREFIX }}_SpiReadReg({{ PREFIX }}_REG_FWDSTAT0, &fwdstat0);
    if (E_OK != status) { return status; }

    status = {{ PREFIX }}_SpiReadReg({{ PREFIX }}_REG_FWDSTAT1, &fwdstat1);
    if (E_OK != status) { return status; }

    seed   = fwdstat0 & {{ PREFIX }}_FWD_SEED_MASK;
    errCnt = fwdstat1 & {{ PREFIX }}_FWD_ERRCNT_MASK;

    if (0U == errCnt) { return E_OK; }

    if (errCnt >= {{ PREFIX }}_CfgPtr->fwdFailMax)
    {
        {{ PREFIX }}_State.faultGroups[{{ PREFIX }}_FAULT_WATCHDOG] |= {{ PREFIX }}_WDG_ERR;
        return E_NOT_OK;
    }

    respVal = {{ PREFIX }}_FwdResTable[seed];

    /* Write 4 response bytes (last to FWDRSPSYNC triggers verify) */
    for (idx = 0U; idx < ({{ PREFIX }}_FWD_RESP_BYTE_CNT - 1U); idx++)
    {
        uint8 byte = (uint8)((respVal >> (24U - (idx * 8U))) & 0xFFU);
        status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_FWDRSP, byte);
        if (E_OK != status) { return status; }
    }

    /* Last byte to FWDRSPSYNC triggers frame synchronization */
    {
        uint8 lastByte = (uint8)(respVal & 0xFFU);
        status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_FWDRSPSYNC, lastByte);
    }

    return status;
}

/*===========================================================================*/
/* WWD Watchdog Service â€?LOCKED                                             */
/*===========================================================================*/
Std_ReturnType {{ PREFIX }}_ServiceWwd(void)
{
    uint8 wwdstat;
    Std_ReturnType status;

    status = {{ PREFIX }}_SpiReadReg({{ PREFIX }}_REG_WWDSTAT, &wwdstat);
    if (E_OK != status) { return status; }

    /* Toggle bit 0 for window watchdog trigger */
    status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_WWDSCMD,
                                      wwdstat ^ {{ PREFIX }}_WWD_BIT0_MASK);
    return status;
}

Std_ReturnType {{ PREFIX }}_ServiceAllWdgs(void)
{
    Std_ReturnType status;
    status = {{ PREFIX }}_ServiceFwd();
    if (E_OK != status) { return status; }
    status = {{ PREFIX }}_ServiceWwd();
    return status;
}

