/*===========================================================================*/
/* Fault Management â€?12 Register Polling with Read-After-Clear              */
/* LOCKED: 0xFF clear + readback verification                                */
/*===========================================================================*/
Std_ReturnType {{ PREFIX }}_ReadFaults({{ PREFIX }}_FaultInfoType *info)
{
    Std_ReturnType status;

    if (NULL_PTR == info) { return E_NOT_OK; }

    status = {{ PREFIX }}_SpiReadReg({{ PREFIX }}_REG_SYSFAIL,  &info->sysFail);
    if (E_OK != status) { return status; }
    status = {{ PREFIX }}_SpiReadReg({{ PREFIX }}_REG_INITERR,  &info->initErr);
    if (E_OK != status) { return status; }
    status = {{ PREFIX }}_SpiReadReg({{ PREFIX }}_REG_IF,       &info->ifReg);
    if (E_OK != status) { return status; }
    status = {{ PREFIX }}_SpiReadReg({{ PREFIX }}_REG_SYSSF,    &info->sysSf);
    if (E_OK != status) { return status; }
    status = {{ PREFIX }}_SpiReadReg({{ PREFIX }}_REG_WKSF,     &info->wkSf);
    if (E_OK != status) { return status; }
    status = {{ PREFIX }}_SpiReadReg({{ PREFIX }}_REG_SPISF,    &info->spiSf);
    if (E_OK != status) { return status; }
    status = {{ PREFIX }}_SpiReadReg({{ PREFIX }}_REG_MONSF0,   &info->monSf0);
    if (E_OK != status) { return status; }
    status = {{ PREFIX }}_SpiReadReg({{ PREFIX }}_REG_MONSF1,   &info->monSf1);
    if (E_OK != status) { return status; }
    status = {{ PREFIX }}_SpiReadReg({{ PREFIX }}_REG_MONSF2,   &info->monSf2);
    if (E_OK != status) { return status; }
    status = {{ PREFIX }}_SpiReadReg({{ PREFIX }}_REG_MONSF3,   &info->monSf3);
    if (E_OK != status) { return status; }
    status = {{ PREFIX }}_SpiReadReg({{ PREFIX }}_REG_OTFAIL,   &info->otFail);
    if (E_OK != status) { return status; }
    status = {{ PREFIX }}_SpiReadReg({{ PREFIX }}_REG_OTWRNSF,  &info->otWrnSf);

    if (E_OK == status)
    {
        {{ PREFIX }}_State.faultInfo = *info;
    }
    return status;
}

Std_ReturnType {{ PREFIX }}_ClearFaults(void)
{
    Std_ReturnType status;
    uint8 verify;

    /* Write 0xFF to clear all fault registers (rw1c type) â€?LOCKED */
    status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_SYSFAIL,  0xFFU);
    if (E_OK != status) { return status; }
    status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_INITERR,  0xFFU);
    if (E_OK != status) { return status; }
    status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_IF,       0xFFU);
    if (E_OK != status) { return status; }
    status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_SYSSF,    0xFFU);
    if (E_OK != status) { return status; }
    status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_WKSF,     0xFFU);
    if (E_OK != status) { return status; }
    status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_SPISF,    0xFFU);
    if (E_OK != status) { return status; }
    status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_MONSF0,   0xFFU);
    if (E_OK != status) { return status; }
    status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_MONSF1,   0xFFU);
    if (E_OK != status) { return status; }
    status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_MONSF2,   0xFFU);
    if (E_OK != status) { return status; }
    status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_MONSF3,   0xFFU);
    if (E_OK != status) { return status; }
    status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_OTFAIL,   0xFFU);
    if (E_OK != status) { return status; }
    status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_OTWRNSF,  0xFFU);
    if (E_OK != status) { return status; }

    /* Read-after-clear verification (Stuck-at fault immunity) â€?LOCKED */
    status = {{ PREFIX }}_SpiReadReg({{ PREFIX }}_REG_SYSFAIL, &verify);
    if ((E_OK == status) && (verify != 0x00U))
    {
        {{ PREFIX }}_State.faultGroups[{{ PREFIX }}_FAULT_CHIP] |= {{ PREFIX }}_SYSTEM_ERR;
        return E_NOT_OK;
    }

    /* Clear accumulated fault group flags */
    {
        uint8 grp;
        for (grp = 0U; grp < {{ PREFIX }}_FAULT_COUNT; grp++)
        {
            {{ PREFIX }}_State.faultGroups[grp] = 0U;
        }
    }

    return E_OK;
}

Std_ReturnType {{ PREFIX }}_ClearFaultReg(uint8 addr)
{
    Std_ReturnType status;
    status = {{ PREFIX }}_SpiWriteReg(addr, 0xFFU);

    /* Read-after-clear verification */
    if (E_OK == status)
    {
        uint8 verify;
        status = {{ PREFIX }}_SpiReadReg(addr, &verify);
        if ((E_OK == status) && (verify != 0x00U))
        {
            status = E_NOT_OK;
        }
    }
    return status;
}

