/*===========================================================================*/
/* EMB Recovery (Tracker2 Fast/Slow Strategy) â€?LOCKED                       */
/*===========================================================================*/
Std_ReturnType {{ PREFIX }}_EmbFastRecovery(void)
{
    Std_ReturnType status;

    status = {{ PREFIX }}_UnlockProtRegs();
    if (E_OK != status) { return status; }

    /* Clear TRK2UV flag only (bit 7 of MONSF2) */
    status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_MONSF2, 0x80U);
    if (E_OK != status) { return status; }

    SuspendAllInterrupts();
    (void){{ PREFIX }}_CfgPtr->delayUsFunc({{ PREFIX }}_CFG_EMB_FAST_DLY_US);
    ResumeAllInterrupts();

    status = {{ PREFIX }}_LockProtRegs();
    return status;
}

Std_ReturnType {{ PREFIX }}_EmbSlowRecovery(void)
{
    Std_ReturnType status;

    status = {{ PREFIX }}_UnlockProtRegs();
    if (E_OK != status) { return status; }

    /* Clear all MONSF2 flags and re-enable tracker */
    status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_MONSF2, 0xFFU);
    if (E_OK != status) { return status; }

    SuspendAllInterrupts();
    (void){{ PREFIX }}_CfgPtr->delayUsFunc({{ PREFIX }}_CFG_EMB_SLOW_DLY_US);
    ResumeAllInterrupts();

    status = {{ PREFIX }}_LockProtRegs();
    return status;
}

/*===========================================================================*/
/* Initialization Phase Machine â€?4x Retry Support, 8 Phases                 */
/* LOCKED                                                                     */
/*===========================================================================*/
static Std_ReturnType {{ PREFIX }}_RunInitPhase(void)
{
    Std_ReturnType status = E_OK;

    switch ({{ PREFIX }}_State.initPhase)
    {
        case {{ PREFIX }}_PHASE_INIT_SPI:
            {{ PREFIX }}_State.initPhase = {{ PREFIX }}_PHASE_INIT_UNLOCK;
            break;

        case {{ PREFIX }}_PHASE_INIT_UNLOCK:
            status = {{ PREFIX }}_UnlockProtRegs();
            if (E_OK == status)
            {
                {{ PREFIX }}_State.initPhase = {{ PREFIX }}_PHASE_INIT_SYSPCFG;
            }
            break;

        case {{ PREFIX }}_PHASE_INIT_SYSPCFG:
            status = {{ PREFIX }}_WriteShadowVerify(
                {{ PREFIX }}_REG_SYSPCFG0, 0x00U, {{ PREFIX }}_REG_RSYSPCFG0);
            if (E_OK == status)
            {
                status = {{ PREFIX }}_WriteShadowVerify(
                    {{ PREFIX }}_REG_SYSPCFG1, 0x00U, {{ PREFIX }}_REG_RSYSPCFG1);
            }
            if (E_OK == status)
            {
                {{ PREFIX }}_State.initPhase = {{ PREFIX }}_PHASE_INIT_WDGCFG;
            }
            break;

        case {{ PREFIX }}_PHASE_INIT_WDGCFG:
            status = {{ PREFIX }}_WriteShadowVerify(
                {{ PREFIX }}_REG_WDCFG0, 0x00U, {{ PREFIX }}_REG_RWDCFG0);
            if (E_OK == status)
            {
                status = {{ PREFIX }}_WriteShadowVerify(
                    {{ PREFIX }}_REG_WDCFG1, 0x00U, {{ PREFIX }}_REG_RWDCFG1);
            }
            if (E_OK == status)
            {
                {{ PREFIX }}_State.initPhase = {{ PREFIX }}_PHASE_INIT_FWDCFG;
            }
            break;

        case {{ PREFIX }}_PHASE_INIT_FWDCFG:
            status = {{ PREFIX }}_WriteShadowVerify(
                {{ PREFIX }}_REG_FWDCFG, 0x00U, {{ PREFIX }}_REG_RFWDCFG);
            if (E_OK == status)
            {
                {{ PREFIX }}_State.initPhase = {{ PREFIX }}_PHASE_INIT_WWDCFG;
            }
            break;

        case {{ PREFIX }}_PHASE_INIT_WWDCFG:
            status = {{ PREFIX }}_WriteShadowVerify(
                {{ PREFIX }}_REG_WWDCFG0, 0x00U, {{ PREFIX }}_REG_RWWDCFG0);
            if (E_OK == status)
            {
                status = {{ PREFIX }}_WriteShadowVerify(
                    {{ PREFIX }}_REG_WWDCFG1, 0x00U, {{ PREFIX }}_REG_RWWDCFG1);
            }
            if (E_OK == status)
            {
                {{ PREFIX }}_State.initPhase = {{ PREFIX }}_PHASE_INIT_BIST;
            }
            break;

        case {{ PREFIX }}_PHASE_INIT_BIST:
            if (0U != {{ PREFIX }}_CfgPtr->bistEnableOnInit)
            {
                status = {{ PREFIX }}_RunFullBist();
            }
            if (E_OK == status)
            {
                {{ PREFIX }}_State.initPhase = {{ PREFIX }}_PHASE_INIT_DONE;
                {{ PREFIX }}_State.isInitialized = TRUE;
                {{ PREFIX }}_IsInitializedLocal = TRUE;
            }
            break;

        case {{ PREFIX }}_PHASE_INIT_DONE:
            break;

        case {{ PREFIX }}_PHASE_INIT_FAILED:
        default:
            status = E_NOT_OK;
            break;
    }
    return status;
}

/*===========================================================================*/
/* Main Function â€?10ms Periodic Scheduler                                   */
/* LOCKED                                                                     */
/*===========================================================================*/
Std_ReturnType {{ PREFIX }}_MainFunction(void)
{
    Std_ReturnType status = E_OK;

    if (NULL_PTR == {{ PREFIX }}_CfgPtr) { return E_NOT_OK; }

    /* Initialize phase machine */
    if (!{{ PREFIX }}_State.isInitialized)
    {
        status = {{ PREFIX }}_RunInitPhase();
        if (E_OK != status)
        {
            {{ PREFIX }}_State.initRetryCnt++;
            if ({{ PREFIX }}_State.initRetryCnt >= {{ PREFIX }}_CfgPtr->initRetryMax)
            {
                {{ PREFIX }}_State.initPhase = {{ PREFIX }}_PHASE_INIT_FAILED;
                {{ PREFIX }}_State.faultGroups[{{ PREFIX }}_FAULT_CHIP] |= {{ PREFIX }}_SYSTEM_ERR;
                return E_NOT_OK;
            }
            SuspendAllInterrupts();
            (void){{ PREFIX }}_CfgPtr->delayUsFunc({{ PREFIX }}_CfgPtr->initRetryDelayUs);
            ResumeAllInterrupts();
        }
        return status;
    }

    /* Operational mode state machine: SERVICE â†?FAULT â†?IDLE cycle */
    switch ({{ PREFIX }}_State.opState)
    {
        case {{ PREFIX }}_OPSTATE_IDLE:
            {{ PREFIX }}_State.opState = {{ PREFIX }}_OPSTATE_READY;
            break;

        case {{ PREFIX }}_OPSTATE_READY:
            status = {{ PREFIX }}_ServiceAllWdgs();
            if (E_OK == status)
            {
                {{ PREFIX }}_State.opState = {{ PREFIX }}_OPSTATE_ACTIVE;
            }
            break;

        case {{ PREFIX }}_OPSTATE_ACTIVE:
        {
            {{ PREFIX }}_FaultInfoType faultInfo;
            status = {{ PREFIX }}_ReadFaults(&faultInfo);
            if (E_OK == status)
            {
                if ((faultInfo.sysFail != 0U) || (faultInfo.monSf0 != 0U) ||
                    (faultInfo.monSf1 != 0U) || (faultInfo.initErr != 0U) ||
                    (faultInfo.otFail != 0U))
                {
                    status = {{ PREFIX }}_ClearFaults();
                }
            }
            {{ PREFIX }}_State.opState = {{ PREFIX }}_OPSTATE_IDLE;
            break;
        }

        case {{ PREFIX }}_OPSTATE_ERROR:
        case {{ PREFIX }}_OPSTATE_BIST:
        default:
            break;
    }

    return status;
}

/*===========================================================================*/
/* Initialization Entry Point                                                */
/*===========================================================================*/
Std_ReturnType {{ PREFIX }}_Init(const {{ PREFIX }}_ConfigType *cfgPtr)
{
    if (NULL_PTR == cfgPtr) { return E_NOT_OK; }

    {{ PREFIX }}_CfgPtr = cfgPtr;

    {{ PREFIX }}_State.currentState    = ({{ PREFIX }}_DeviceStateType)0xFFU;
    {{ PREFIX }}_State.targetState     = {{ PREFIX }}_DEVSTATE_INIT;
    {{ PREFIX }}_State.initPhase       = {{ PREFIX }}_PHASE_INIT_SPI;
    {{ PREFIX }}_State.opState         = {{ PREFIX }}_OPSTATE_IDLE;
    {{ PREFIX }}_State.initRetryCnt    = 0U;
    {{ PREFIX }}_State.fwdErrCnt       = 0U;
    {{ PREFIX }}_State.isInitialized   = FALSE;
    {{ PREFIX }}_State.bistPassed      = FALSE;
    {{ PREFIX }}_IsInitializedLocal    = FALSE;

    {
        uint8 grp;
        for (grp = 0U; grp < {{ PREFIX }}_FAULT_COUNT; grp++)
        {
            {{ PREFIX }}_State.faultGroups[grp] = 0U;
        }
