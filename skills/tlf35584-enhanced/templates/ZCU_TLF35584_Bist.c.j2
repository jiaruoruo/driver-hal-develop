/*===========================================================================*/
/* Local Helper â€?Run Single ABIST Path                                      */
/*===========================================================================*/
static Std_ReturnType {{ PREFIX }}_RunSingleAbistPath(uint8 path)
{
    Std_ReturnType status;
    uint8 statusReg;

    /* 1. Clear any previous ABIST results */
    status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_ABIST_CTRL0, 0x00U);
    if (E_OK != status) { return status; }

    /* 2. Configure ABIST_SELECT registers for the given path */
    {
        uint8 selVal;
        switch (path)
        {
            case 0U: selVal = 0x01U; break;  /* Interrupt Path */
            case 1U: selVal = 0x02U; break;  /* Safety Path   */
            case 2U: selVal = 0x04U; break;  /* FWD           */
            case 3U: selVal = 0x08U; break;  /* WWD           */
            case 4U: selVal = 0x10U; break;  /* ERR PIN       */
            default: return E_NOT_OK;
        }
        status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_ABIST_SEL0, selVal);
        if (E_OK != status) { return status; }
        status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_ABIST_SEL1, selVal);
        if (E_OK != status) { return status; }
        status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_ABIST_SEL2, selVal);
        if (E_OK != status) { return status; }
    }

    /* 3. Start single ABIST: INT bit + SINGLE bit + PATH bit + START bit */
    status = {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_ABIST_CTRL0,
        (uint8)({{ PREFIX }}_ABIST_INT_BIT | {{ PREFIX }}_ABIST_SINGLE_BIT |
                {{ PREFIX }}_ABIST_PATH_BIT | {{ PREFIX }}_ABIST_START_BIT));
    if (E_OK != status) { return status; }

    /* 4. Wait for completion (poll STATUS register) */
    {
        uint32 pollCount = 0U;
        const uint32 maxPoll = 10000U;

        do {
            SuspendAllInterrupts();
            (void){{ PREFIX }}_CfgPtr->delayUsFunc(10U);
            ResumeAllInterrupts();

            status = {{ PREFIX }}_SpiReadReg({{ PREFIX }}_REG_ABIST_CTRL1, &statusReg);
            if (E_OK != status) { return status; }

            pollCount++;
            if (pollCount > maxPoll)
            {
                return E_NOT_OK; /* Timeout */
            }
        } while ((statusReg & 0x01U) != 0x00U); /* Wait for BUSY=0 */
    }

    /* 5. Check result */
    status = {{ PREFIX }}_SpiReadReg({{ PREFIX }}_REG_ABIST_CTRL0, &statusReg);
    if (E_OK != status) { return status; }

    /* Expected result: bit 6 (PASS) should be set */
    if ((statusReg & {{ PREFIX }}_ABIST_STATUS_OK) != {{ PREFIX }}_ABIST_STATUS_OK)
    {
        return E_NOT_OK;
    }

    /* 6. Clear ABIST registers */
    {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_ABIST_CTRL0, 0x00U);
    {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_ABIST_SEL0, 0x00U);
    {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_ABIST_SEL1, 0x00U);
    {{ PREFIX }}_SpiWriteReg({{ PREFIX }}_REG_ABIST_SEL2, 0x00U);

    return E_OK;
}

/*===========================================================================*/
/* Public API: Run Single BIST Path                                          */
/*===========================================================================*/
Std_ReturnType {{ PREFIX }}_RunBistSingle(uint8 path)
{
    if (path > 4U) { return E_NOT_OK; }
    return {{ PREFIX }}_RunSingleAbistPath(path);
}

/*===========================================================================*/
/* Public API: Run Full BIST Sequence (all 5 paths)                          */
/*===========================================================================*/
Std_ReturnType {{ PREFIX }}_RunFullBist(void)
{
    Std_ReturnType status;
    uint8 path;

    for (path = 0U; path < 5U; path++)
    {
        status = {{ PREFIX }}_RunSingleAbistPath(path);
        if (E_OK != status)
        {
            {{ PREFIX }}_State.bistPassed = FALSE;
            {{ PREFIX }}_State.faultGroups[{{ PREFIX }}_FAULT_BIST] |= {{ PREFIX }}_BIST_ERR;
            return status;
        }
    }

    {{ PREFIX }}_State.bistPassed = TRUE;
    return E_OK;
}

/*===========================================================================*/
/* Public API: Get BIST Result                                               */
/*===========================================================================*/
boolean {{ PREFIX }}_GetBistResult(void)
{
    return {{ PREFIX }}_State.bistPassed;
}

